# ─── Server ───────────────────────────────────────────────────────────────────
# AutoRouter 对外唯一入口，所有 CDP 请求通过此端口路由。
# 客户端（chrome-devtools-mcp / agent-browser / curl）只看到这个端口，
# 不必感知下游真实 chrome 的端口。
SERVER_HOST=127.0.0.1
SERVER_PORT=9223

# ─── Compatibility Mode ──────────────────────────────────────────────────────
# 根路径兼容路由（/json/version, /json/list 等）是否启用。
# 启用后，下游若不知道 9223 是 autorouter，可直接当作裸 CDP 端口使用。
COMPAT_MODE_ENABLED=true
# 首次 CDP 请求到达时是否懒启动默认实例（不预热，节省冷启资源）。
COMPAT_LAZY_LOAD_ENABLED=true

# ─── Default Instance ────────────────────────────────────────────────────────
# 默认实例 ID。根路径兼容路由隐式使用此实例。
DEFAULT_INSTANCE_ID=default

# 默认实例模式：
#   managed  = autorouter 自动拉起 Chrome 并管理生命周期（推荐：零配置心智）
#   attached = 连接已有的外部 Chrome（需自行确保目标可达）
DEFAULT_INSTANCE_MODE=managed

# managed 模式：Chrome 可执行文件路径（留空则读 CHROME_EXECUTABLE_PATH 环境变量）。
# Windows 默认安装位置示例：
#   C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux 示例：
#   /usr/bin/google-chrome
# macOS 示例：
#   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
DEFAULT_INSTANCE_EXECUTABLE_PATH=

# managed 模式：Chrome 启动参数（空格分隔）。
DEFAULT_INSTANCE_CHROME_ARGS=
# managed 模式：是否无头启动。
DEFAULT_INSTANCE_HEADLESS=false
# managed 模式：Chrome profile 目录（留空则在 .tmp/ 下自动创建并由 autorouter 清理）。
DEFAULT_INSTANCE_USER_DATA_DIR=

# managed 模式：固定下游 chrome 调试端口。留空则 autorouter 自动挑空闲端口。
# ⚠️ 此值必须 ≠ SERVER_PORT，否则会自指环。
# DEFAULT_INSTANCE_REMOTE_DEBUGGING_PORT=

# attached 模式专用：外部 Chrome 的 HTTP 端点。
# ⚠️ 此 URL 是 server 进程视角下的"下游 chrome"地址，
#    绝不能指向 autorouter 自身（不能写 http://127.0.0.1:9223），
#    否则 autorouter 会把请求转发给自己造成自指环。
# DEFAULT_INSTANCE_BROWSER_URL=http://127.0.0.1:9222

# 直连 WS 端点（可选，优先级高于 browserUrl 的自动发现）。
# DEFAULT_INSTANCE_WS_ENDPOINT=

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LOG_FILE=
