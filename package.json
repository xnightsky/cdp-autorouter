{
  "name": "chrome-devtools-mcp-autorouter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP+WS autorouter between chrome-devtools-mcp and real Chrome instances",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
